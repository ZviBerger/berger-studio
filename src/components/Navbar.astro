---
import { getLocaleFromPath, withLocale } from '../utils/i18n';

const locale = getLocaleFromPath(Astro.url.pathname);
const isEnglish = locale === 'en';
const homePaths = isEnglish ? ['/en', '/en/'] : ['/'];
const basePath = isEnglish ? '/en' : '';
const isHomePage = homePaths.includes(Astro.url.pathname);
const navLinks = [
  { href: isHomePage ? '#about' : `${basePath}/#about`, label: isEnglish ? 'About' : 'אודות' },
  { href: isHomePage ? '#portfolio' : `${basePath}/#portfolio`, label: isEnglish ? 'Portfolio' : 'פורטפוליו' },
  { href: isHomePage ? '#services' : `${basePath}/#services`, label: isEnglish ? 'Services' : 'שירותים' },
  { href: isHomePage ? '#contact' : `${basePath}/#contact`, label: isEnglish ? 'Contact' : 'צור קשר' },
];
const switchHref = withLocale(Astro.url.pathname, isEnglish ? 'he' : 'en');
const switchLabel = isEnglish ? 'עברית' : 'English';
const navLabel = isEnglish ? 'Primary navigation' : 'ניווט ראשי';
const backToTopLabel = isEnglish ? 'Alma - back to top' : 'עלמא - חזרה לתחילת העמוד';
const openMenuLabel = isEnglish ? 'Open main menu' : 'פתיחת תפריט ראשי';
const openMenuText = isEnglish ? 'Open menu' : 'פתיחת תפריט';
const mobileNavLabel = isEnglish ? 'Mobile navigation' : 'ניווט נייד';
const closeMenuLabel = isEnglish ? 'Close main menu' : 'סגירת תפריט ראשי';
const brandLabel = isEnglish ? 'Alma.' : 'עלמא.';
---

<nav
  class="w-full py-6 px-8 md:px-16 flex justify-between items-center fixed top-0 z-50 text-white transition-all duration-500"
  id="navbar"
  aria-label={navLabel}
>
  <a
    href={isHomePage ? '#home' : `${basePath}/#home`}
    class="group relative z-50 transition-opacity duration-300"
    aria-label={backToTopLabel}
    id="navbar-logo"
  >
    <div class="flex items-center" dir={isEnglish ? 'ltr' : 'rtl'}>
      <div class="text-3xl font-bold tracking-tighter">{brandLabel}</div>
    </div>
  </a>

  <div class="hidden md:flex items-center gap-8">
    <ul class="flex items-center gap-12 text-sm font-medium tracking-[0.12em] list-none m-0 p-0" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="nav-link inline-block hover:opacity-70 transition-opacity duration-300">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a
      href={switchHref}
      class="inline-flex items-center rounded-full border border-current/30 px-4 py-2 text-xs font-medium tracking-[0.18em] uppercase hover:bg-white hover:text-black transition-colors duration-300"
    >
      {switchLabel}
    </a>
  </div>

  <button
    type="button"
    class="md:hidden relative z-50 w-10 h-10 flex flex-col justify-center gap-2 group"
    aria-label={openMenuLabel}
    aria-controls="mobile-menu"
    aria-expanded="false"
    id="menu-btn"
  >
    <span class="sr-only">{openMenuText}</span>
    <span class="w-full h-[1px] bg-current transition-all duration-300 origin-center"></span>
    <span class="w-full h-[1px] bg-current transition-all duration-300 origin-center"></span>
  </button>
</nav>

<div
  id="mobile-menu"
  class="fixed inset-0 bg-black z-40 translate-x-full transition-transform duration-700 ease-[cubic-bezier(0.76,0,0.24,1)] flex items-center justify-center"
  aria-hidden="true"
>
  <nav aria-label={mobileNavLabel}>
    <ul class="flex flex-col gap-8 text-4xl font-light text-white text-center list-none m-0 p-0" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="mobile-link hover:opacity-70 transition-opacity">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href={switchHref}
          class="mobile-link inline-flex items-center justify-center rounded-full border border-white/30 px-6 py-3 text-base uppercase tracking-[0.18em]"
        >
          {switchLabel}
        </a>
      </li>
    </ul>
  </nav>
</div>

<script define:vars={{ openMenuLabel, closeMenuLabel, homePaths }}>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const links = Array.from(document.querySelectorAll('.mobile-link'));
  const spans = menuBtn?.querySelectorAll('span:not(.sr-only)');
  const focusableSelector =
    'a[href], button:not([disabled]), input:not([disabled]), textarea:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])';
  let isOpen = false;
  let lastFocusedElement = null;

  function setMenuState(open) {
    isOpen = open;

    if (!menuBtn || !mobileMenu) {
      return;
    }

    menuBtn.setAttribute('aria-expanded', String(open));
    menuBtn.setAttribute('aria-label', open ? closeMenuLabel : openMenuLabel);
    mobileMenu.setAttribute('aria-hidden', String(!open));

    if (open) {
      mobileMenu.classList.remove('translate-x-full');
      document.body.classList.add('overflow-hidden');
      spans?.[0]?.classList.add('rotate-45', 'translate-y-[4.5px]');
      spans?.[1]?.classList.add('-rotate-45', '-translate-y-[4.5px]');
      lastFocusedElement = document.activeElement;
      const firstFocusable = mobileMenu.querySelector(focusableSelector);
      if (firstFocusable instanceof HTMLElement) {
        firstFocusable.focus();
      }
      return;
    }

    mobileMenu.classList.add('translate-x-full');
    document.body.classList.remove('overflow-hidden');
    spans?.[0]?.classList.remove('rotate-45', 'translate-y-[4.5px]');
    spans?.[1]?.classList.remove('-rotate-45', '-translate-y-[4.5px]');
    if (lastFocusedElement instanceof HTMLElement) {
      lastFocusedElement.focus();
    }
  }

  function toggleMenu() {
    setMenuState(!isOpen);
  }

  function handleKeydown(event) {
    if (!isOpen || !mobileMenu) {
      return;
    }

    if (event.key === 'Escape') {
      setMenuState(false);
      return;
    }

    if (event.key !== 'Tab') {
      return;
    }

    const focusableItems = Array.from(mobileMenu.querySelectorAll(focusableSelector)).filter(
      (element) => element instanceof HTMLElement && !element.hasAttribute('disabled'),
    );

    if (focusableItems.length === 0) {
      return;
    }

    const firstElement = focusableItems[0];
    const lastElement = focusableItems[focusableItems.length - 1];

    if (event.shiftKey && document.activeElement === firstElement) {
      event.preventDefault();
      lastElement.focus();
    } else if (!event.shiftKey && document.activeElement === lastElement) {
      event.preventDefault();
      firstElement.focus();
    }
  }

  menuBtn?.addEventListener('click', toggleMenu);
  links.forEach((link) =>
    link.addEventListener('click', () => {
      setMenuState(false);
    }),
  );
  document.addEventListener('keydown', handleKeydown);

  window.addEventListener(
    'scroll',
    () => {
      const nav = document.getElementById('navbar');
      const logo = document.getElementById('navbar-logo');
      const isMobile = window.innerWidth < 768;
      if (!nav || isOpen) {
        return;
      }

      if (window.scrollY > window.innerHeight - 80) {
        nav.classList.add('py-4', 'bg-white', 'text-black');
        nav.classList.remove('py-6', 'text-white');
        if (isMobile) {
          logo?.classList.remove('opacity-0', 'pointer-events-none');
        }
      } else {
        nav.classList.add('py-6', 'text-white');
        nav.classList.remove('py-4', 'bg-white', 'text-black');
        if (isMobile && homePaths.includes(window.location.pathname)) {
          logo?.classList.add('opacity-0', 'pointer-events-none');
        }
      }
    },
    { passive: true },
  );

  window.addEventListener('load', () => {
    const logo = document.getElementById('navbar-logo');
    if (window.innerWidth < 768 && homePaths.includes(window.location.pathname) && window.scrollY < window.innerHeight - 80) {
      logo?.classList.add('opacity-0', 'pointer-events-none');
    }
  });
</script>
