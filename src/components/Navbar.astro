---
---
<nav class="w-full py-6 px-8 md:px-16 flex justify-between items-center fixed top-0 z-50 mix-blend-difference text-white transition-all duration-500" id="navbar">
  <!-- Logo -->
  <a href="#home" class="group relative z-50">
    <div class="flex items-center gap-3" dir="ltr">
      <img
        src="/logo.svg"
        alt="Berger Studio"
        class="w-7 h-7 object-contain invert opacity-95"
        loading="eager"
      />
      <div class="text-2xl font-bold tracking-tight uppercase">
        Berger<span class="font-light opacity-70">Studio</span>
      </div>
    </div>
  </a>

  <!-- Desktop Menu -->
  <div class="hidden md:flex gap-12 text-sm font-medium tracking-[0.2em] uppercase">
    <a href="#about" class="nav-link relative overflow-hidden group">
      <span class="block transition-transform duration-500 group-hover:-translate-y-full">אודות</span>
      <span class="absolute top-0 left-0 block transition-transform duration-500 translate-y-full group-hover:translate-y-0 opacity-50">אודות</span>
    </a>
    <a href="#portfolio" class="nav-link relative overflow-hidden group">
      <span class="block transition-transform duration-500 group-hover:-translate-y-full">פורטפוליו</span>
      <span class="absolute top-0 left-0 block transition-transform duration-500 translate-y-full group-hover:translate-y-0 opacity-50">פורטפוליו</span>
    </a>
    <a href="#services" class="nav-link relative overflow-hidden group">
      <span class="block transition-transform duration-500 group-hover:-translate-y-full">שירותים</span>
      <span class="absolute top-0 left-0 block transition-transform duration-500 translate-y-full group-hover:translate-y-0 opacity-50">שירותים</span>
    </a>
    <a href="#contact" class="nav-link relative overflow-hidden group">
      <span class="block transition-transform duration-500 group-hover:-translate-y-full">צור קשר</span>
      <span class="absolute top-0 left-0 block transition-transform duration-500 translate-y-full group-hover:translate-y-0 opacity-50">צור קשר</span>
    </a>
  </div>

  <!-- Mobile Menu Button -->
  <button class="md:hidden relative z-50 w-10 h-10 flex flex-col justify-center gap-2 group" aria-label="Menu" id="menu-btn">
    <span class="w-full h-[1px] bg-current transition-all duration-300 origin-center"></span>
    <span class="w-full h-[1px] bg-current transition-all duration-300 origin-center"></span>
  </button>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-black z-40 translate-x-full transition-transform duration-700 ease-[cubic-bezier(0.76,0,0.24,1)] flex items-center justify-center">
    <div class="flex flex-col gap-8 text-4xl font-light text-white text-center">
        <a href="#about" class="mobile-link hover:opacity-50 transition-opacity">אודות</a>
        <a href="#portfolio" class="mobile-link hover:opacity-50 transition-opacity">פורטפוליו</a>
        <a href="#services" class="mobile-link hover:opacity-50 transition-opacity">שירותים</a>
        <a href="#contact" class="mobile-link hover:opacity-50 transition-opacity">צור קשר</a>
    </div>
</div>

<script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const links = document.querySelectorAll('.mobile-link');
    const spans = menuBtn?.querySelectorAll('span');
    let isOpen = false;

    function toggleMenu() {
        isOpen = !isOpen;
        if (isOpen) {
            mobileMenu?.classList.remove('translate-x-full');
            document.body.classList.add('overflow-hidden');
            spans?.[0].classList.add('rotate-45', 'translate-y-[4.5px]');
            spans?.[1].classList.add('-rotate-45', '-translate-y-[4.5px]');
        } else {
            mobileMenu?.classList.add('translate-x-full');
            document.body.classList.remove('overflow-hidden');
            spans?.[0].classList.remove('rotate-45', 'translate-y-[4.5px]');
            spans?.[1].classList.remove('-rotate-45', '-translate-y-[4.5px]');
        }
    }

    menuBtn?.addEventListener('click', toggleMenu);
    links.forEach(link => link.addEventListener('click', toggleMenu));

    // Navbar scroll effect
    window.addEventListener('scroll', () => {
        const nav = document.getElementById('navbar');
        if (window.scrollY > 50) {
            nav?.classList.add('py-4');
            nav?.classList.remove('py-6');
        } else {
            nav?.classList.add('py-6');
            nav?.classList.remove('py-4');
        }
    });
</script>