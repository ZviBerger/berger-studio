---
const year = new Date().getFullYear();
---

<footer class="w-full py-12 px-6 md:px-12 border-t border-berger-brown/10 mt-auto">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
    <div class="flex flex-col gap-2">
      <h2 class="text-xl font-semibold">עלמא</h2>
      <p class="text-sm text-stone-700">אדריכלות ועיצוב פנים</p>
    </div>

    <nav aria-label="קישורי תחתית">
      <ul class="flex flex-wrap gap-6 text-sm md:text-base" role="list">
        <li>
          <a href="/#contact" class="hover:underline">צור קשר</a>
        </li>
        <li>
          <a href="/accessibility-statement" class="hover:underline">הצהרת נגישות</a>
        </li>
        <li>
          <a href="mailto:Chila.eh@gmail.com" class="hover:underline" dir="ltr">Chila.eh@gmail.com</a>
        </li>
      </ul>
