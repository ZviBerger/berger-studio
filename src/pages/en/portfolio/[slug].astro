---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('portfolioEn');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const imageAlt = entry.data.description
  ? `${entry.data.title} - ${entry.data.description}`
  : `Project image for ${entry.data.title}`;
---

<Layout
  title={`${entry.data.title} | Alma`}
  description={entry.data.description}
  ogImage={entry.data.coverImage}
  ogType="article"
>
  <Navbar />

  <main id="main-content" tabindex="-1">
    <article class="min-h-screen pt-24">
      <div class="w-full h-[60vh] bg-gray-100 overflow-hidden relative">
        {entry.data.coverImage ? (
          <img
            src={entry.data.coverImage}
            alt={imageAlt}
            class="w-full h-full object-cover"
          />
        ) : (
          <div class="w-full h-full flex items-center justify-center text-stone-600">Image coming soon</div>
        )}
        <div class="absolute inset-0 bg-black/10" aria-hidden="true"></div>
      </div>

      <div class="max-w-4xl mx-auto px-6 md:px-12 py-16">
        <header class="mb-12 border-b border-berger-brown/10 pb-8">
          <div class="flex justify-between items-start gap-4 mb-4">
            <span class="text-sm tracking-widest uppercase text-stone-700">{entry.data.category}</span>
            <span class="text-sm text-stone-700">{entry.data.publishDate.toLocaleDateString('en-US')}</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-serif">{entry.data.title}</h1>
        </header>

        <div class="prose prose-xl prose-stone prose-headings:font-light prose-p:text-berger-brown/90 max-w-none">
          <Content />
        </div>

        <div class="mt-16 pt-8 border-t border-berger-brown/10">
          <a href="/en/#portfolio" class="hover:opacity-60 transition-opacity">Back to homepage</a>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</Layout>
