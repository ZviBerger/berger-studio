---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('portfolio');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | Berger Studio`}>
    <Navbar />
    
    <article class="min-h-screen">
        <!-- Hero Image -->
        <div class="w-full h-[60vh] bg-gray-100 overflow-hidden relative">
             {entry.data.coverImage ? (
                <img src={entry.data.coverImage} alt={entry.data.title} class="w-full h-full object-cover" />
             ) : (
                <div class="w-full h-full flex items-center justify-center text-gray-400">תמונה בקרוב</div>
             )}
             <div class="absolute inset-0 bg-black/10"></div>
        </div>

        <div class="max-w-4xl mx-auto px-6 md:px-12 py-16">
            <!-- Header -->
            <div class="mb-12 border-b border-berger-brown/10 pb-8">
                <div class="flex justify-between items-start mb-4">
                    <span class="text-sm tracking-widest uppercase opacity-60">{entry.data.category}</span>
                    <span class="text-sm opacity-60">{entry.data.publishDate.toLocaleDateString('he-IL')}</span>
                </div>
                <h1 class="text-4xl md:text-5xl font-serif">{entry.data.title}</h1>
            </div>

            <!-- Content -->
            <div class="prose prose-xl prose-stone prose-headings:font-light prose-p:text-berger-brown/80 max-w-none">
                <Content />
            </div>

            <!-- Back Link -->
            <div class="mt-16 pt-8 border-t border-berger-brown/10">
                <a href="/portfolio" class="hover:opacity-60 transition-opacity">&larr; חזרה לכל הפרויקטים</a>
            </div>
        </div>
    </article>

    <Footer />
</Layout>
