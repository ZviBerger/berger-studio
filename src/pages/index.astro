---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('portfolio');
const featuredProjects = allProjects.filter(p => p.data.featured);
---

<Layout title="Berger Studio | Architecture & Design">
	<Navbar />
	
	<main class="bg-white text-black selection:bg-black selection:text-white">
		
		<!-- Hero Section -->
		<section id="home" class="relative h-screen w-full overflow-hidden">
            <div class="absolute inset-0">
                <!-- Parallax Wrapper -->
                <div id="parallax-bg" class="absolute inset-0 h-[140%] -top-[20%] w-full will-change-transform">
                     <img 
                        src="/hero.jpg" 
                        alt="Hero" 
                        class="w-full h-full object-cover animate-ken-burns"
                    />
                </div>
                <!-- Overlay inside parallax wrapper or static? Static to cover screen properly -->
                <div class="absolute inset-0 bg-black/20 pointer-events-none"></div>
            </div>
			
			<div class="relative z-10 h-full flex flex-col justify-between p-8 md:p-16 pb-12">
                

				<div class="max-w-[90vw]">
					<h1 class="text-7xl md:text-[11vw] leading-[0.85] font-normal tracking-tight text-white mix-blend-overlay">
						<span class="block reveal-text" style="animation-delay: 0.1s">Material.</span>
						<span class="block reveal-text ml-[10vw]" style="animation-delay: 0.3s">Meaning.</span>
						<span class="block reveal-text" style="animation-delay: 0.5s">Mood.</span>
					</h1>
				</div>

                <div class="flex justify-between items-end text-white border-t border-white/30 pt-6">
                    <p class="text-sm md:text-base font-light max-w-md tracking-wide opacity-90">
                        סטודיו לאדריכלות ועיצוב פנים המתמחה בחללי מגורים יוקרתיים ופרויקטים מסחריים.
                    </p>
                    <div class="animate-bounce text-2xl">↓</div>
                </div>
			</div>
		</section>

		<!-- Inspiration Section (Formerly Portfolio) -->
		<section id="portfolio" class="py-32 px-8 md:px-16 bg-white overflow-hidden">
            <div class="max-w-[1800px] mx-auto">
                <div class="mb-32 flex justify-between items-end">
                    <h2 class="text-5xl md:text-9xl font-light tracking-tighter text-black">השראה</h2>
                    <p class="text-sm font-bold tracking-[0.3em] uppercase text-gray-400 mb-4 hidden md:block">Gallery of Vision</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-y-48">
                    <!-- Image 1: Vertical (Was Wide) -->
                    <div class="md:col-span-5 group relative">
                        <div class="aspect-[3/4] overflow-hidden bg-stone-100 mb-8">
                            <img src="/Screenshot 2025-12-26 at 0.40.22.png" alt="Warm Minimalism" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" />
                        </div>
                        <div class="max-w-md">
                            <span class="text-xs font-mono text-gray-400 mb-2 block tracking-widest">STYLE 01</span>
                            <h3 class="text-3xl font-light mb-4">מינימליזם אורגני</h3>
                            <p class="text-gray-500 font-light leading-relaxed">
                                המפגש בין קווים גיאומטריים נוקשים לבין חומרים טבעיים וצורות אמורפיות. יצירת חלל שנושם יחד עם דייריו.
                            </p>
                        </div>
                    </div>

                    <!-- Image 2: Wide (Was Vertical) - Swapped Layout logic to balance -->
                    <div class="md:col-span-7 md:mt-32 group relative">
                        <div class="aspect-[16/9] overflow-hidden bg-stone-100 mb-8">
                            <img src="/Screenshot 2025-12-26 at 0.40.33.png" alt="Light Study" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" />
                        </div>
                        <div class="max-w-xs mr-auto">
                            <span class="text-xs font-mono text-gray-400 mb-2 block tracking-widest">STYLE 02</span>
                            <h3 class="text-3xl font-light mb-4">דיאלוג עם האור</h3>
                            <p class="text-gray-500 font-light leading-relaxed">
                                האור הוא החומר השקוף ביותר בתהליך התכנון. אנחנו משתמשים בו כדי לפסל את החלל ולהעניק לו עומק משתנה לאורך שעות היום.
                            </p>
                        </div>
                    </div>

                    <!-- Image 3: Vertical Split (RTL Side) -->
                    <div class="md:col-span-5 group relative">
                        <div class="aspect-[4/5] overflow-hidden bg-stone-100 mb-8">
                            <img src="/Screenshot 2025-12-26 at 0.40.41.png" alt="Craftsmanship" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" />
                        </div>
                        <div class="max-w-sm">
                            <span class="text-xs font-mono text-gray-400 mb-2 block tracking-widest">STYLE 03</span>
                            <h3 class="text-3xl font-light mb-4">אדריכלות של פרטים</h3>
                            <p class="text-gray-500 font-light leading-relaxed">
                                אמונה שהשלם גדול מסכום חלקיו רק כאשר כל חלק מטופל בחרדת קודש. נגרות אומן, חיבורי חומרים ודיוק של מילימטרים.
                            </p>
                        </div>
                    </div>

                    <!-- Image 4: Horizontal (Overlap feel) -->
                    <div class="md:col-span-7 md:-mt-32 group relative">
                        <div class="aspect-[16/10] overflow-hidden bg-stone-100 mb-8 shadow-2xl md:z-10 relative">
                            <img src="/Screenshot 2025-12-26 at 0.40.53.png" alt="Natural Materials" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" />
                        </div>
                        <div class="max-w-md md:mr-auto">
                            <span class="text-xs font-mono text-gray-400 mb-2 block tracking-widest">STYLE 04</span>
                            <h3 class="text-3xl font-light mb-4">חומרים שמרגישים</h3>
                            <p class="text-gray-500 font-light leading-relaxed">
                                אבן טבעית, עץ אלון מוברש וברזל חשוף. אנחנו בוחרים חומרים שמתיישנים בכבוד ומספרים סיפור של אותנטיות וחיבור לאדמה.
                            </p>
                        </div>
                    </div>

                    <!-- Image 5: Cinematic Full Width -->
                    <div class="md:col-span-12 group relative border-t border-black/5 pt-32">
                        <div class="aspect-[21/9] overflow-hidden bg-stone-100 mb-12">
                            <img src="/Screenshot 2025-12-26 at 0.41.01.png" alt="Modern Wellness" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" />
                        </div>
                        <div class="flex flex-col md:flex-row justify-between items-start gap-8">
                            <div class="max-w-xl">
                                <span class="text-xs font-mono text-gray-400 mb-2 block tracking-widest">STYLE 05</span>
                                <h3 class="text-5xl font-light mb-6">מקדש של שקט</h3>
                                <p class="text-xl text-gray-500 font-light leading-relaxed">
                                    חללי רחצה ו-Wellness שהופכים למפלט מהעולם החיצון. שימוש בשיש טבעי ובקווים נקיים ליצירת חוויה של רוגע מוחלט.
                                </p>
                            </div>
                            <div class="h-[1px] w-full md:w-64 bg-black self-end mb-4"></div>
                        </div>
                    </div>

                    <!-- Image 6: Entrance (New) -->
                    <div class="md:col-span-6 group relative" data-aos="fade-up">
                        <div class="aspect-[3/4] overflow-hidden bg-stone-100 mb-8">
                            <img src="/WhatsApp Image 2025-12-26 at 01.38.00.jpeg" alt="Entrance Design" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" />
                        </div>
                        <div class="max-w-md">
                            <span class="text-xs font-mono text-gray-400 mb-2 block tracking-widest">STYLE 06</span>
                            <h3 class="text-3xl font-light mb-4">המפגש הראשון</h3>
                            <p class="text-gray-500 font-light leading-relaxed">
                                עיצוב מבואת כניסה המשלב חומרים חמים עם אלמנטים גיאומטריים מזמינים. יצירת מעבר הדרגתי ונעים מהחוץ אל הפנים.
                            </p>
                        </div>
                    </div>

                    <!-- Image 7: Dark Kitchen (New) -->
                    <div class="md:col-span-6 md:mt-32 group relative" data-aos="fade-up">
                        <div class="aspect-[3/4] overflow-hidden bg-stone-100 mb-8">
                            <img src="/WhatsApp Image 2025-12-26 at 01.40.12.jpeg" alt="Dark Minimalist Kitchen" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" />
                        </div>
                        <div class="max-w-md">
                            <span class="text-xs font-mono text-gray-400 mb-2 block tracking-widest">STYLE 07</span>
                            <h3 class="text-3xl font-light mb-4">דרמה מאופקת</h3>
                            <p class="text-gray-500 font-light leading-relaxed">
                                מטבחים במינימליזם כהה ומוקפד. שימוש בטקסטורות עץ עמוקות בשילוב אי מאבן טבעית ליצירת מראה יוקרתי ועל-זמני.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
		</section>

		<!-- About Section - Editorial Layout -->
		<section id="about" class="py-32 md:py-48 px-8 md:px-16 max-w-[1800px] mx-auto">
            <div class="flex flex-col md:flex-row gap-24 items-start">
                <div class="w-full md:w-1/3 sticky top-32">
                    <span class="text-xs font-bold tracking-[0.2em] uppercase text-gray-400 mb-8 block">The Studio</span>
                    <h2 class="text-5xl md:text-6xl font-light leading-tight mb-12">
                        עיצוב שקט,<br>
                        נוכחות עוצמתית.
                    </h2>
                    <div class="h-[1px] w-24 bg-black mb-12"></div>
                    <div class="flex flex-col gap-2">
                        <span class="text-lg font-medium">חני ברגר</span>
                        <span class="text-sm text-gray-500 uppercase tracking-widest">אדריכלית ראשית</span>
                    </div>
                </div>

                <div class="w-full md:w-2/3 flex flex-col gap-32">
                    <div class="relative group">
                        <div class="overflow-hidden mb-8 aspect-[4/5] max-w-lg">
                            <img src="/Chani.jpg" alt="Hani Berger" class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105" />
                        </div>
                        <div class="md:pl-24 max-w-2xl space-y-8">
                            <p class="text-xl md:text-2xl font-light leading-relaxed text-gray-800">
                                הסטודיו מביא עמו ניסיון עשיר של למעלה מ-8 שנים בתכנון מגה-פרויקטים ומבנים מורכבים בארץ ובחו"ל.
                                חני הובילה תכנון בפרויקטים אייקוניים כמו מגדלי <strong class="font-normal">Beyond (תדהר)</strong> – פרויקט הדגל בגבעתיים המשלב מגדל משרדים בן 70 קומות ומגדל מגורים בן 45 קומות.
                            </p>
                            <p class="text-lg font-light leading-relaxed text-gray-600">
                                הניסיון המקצועי שלה, שנצבר במשרד המוביל <strong class="font-normal">ברעלי לויצקי כסיף (B.L.K)</strong>, כולל עבודה על פרויקטים רחבי היקף כמו "סביוני השרון" בנתניה ופרויקט "הגדוד העברי". יכולות אלו, המשלבות ראייה אסטרטגית וניהול צוותים בינלאומיים, מתורגמות כיום לסטודיו בוטיק המעניק תשומת לב אישית ודיוק אדריכלי חסר פשרות.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
		</section>

        <!-- Services - Horizontal Scroll / List -->
        <section id="services" class="py-32 border-t border-gray-100">
            <div class="px-8 md:px-16 mb-24 flex justify-between items-end">
                <h2 class="text-4xl md:text-8xl font-light tracking-tighter">שירותים</h2>
                <span class="text-xs font-bold tracking-[0.2em] uppercase text-gray-400 mb-4 hidden md:block">Expertise</span>
            </div>

            <div class="flex flex-col">
                <!-- Item 1 -->
                <div class="group border-t border-black/10 py-16 px-8 md:px-16 hover:bg-stone-50 transition-colors duration-500 cursor-pointer relative overflow-hidden">
                    <div class="flex flex-col md:flex-row justify-between items-baseline relative z-10">
                        <span class="text-sm font-mono text-gray-400 mb-4 md:mb-0">01</span>
                        <h3 class="text-4xl md:text-6xl font-light group-hover:translate-x-4 transition-transform duration-500">עיצוב פנים</h3>
                        <p class="text-base text-gray-500 max-w-xs mt-4 md:mt-0 text-left md:text-right">תכנון חללים מוקפד וטוטאלי</p>
                    </div>
                    <!-- Hover Image Float -->
                    <div class="hidden md:block absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 w-[400px] h-[300px] opacity-0 group-hover:opacity-100 transition-all duration-500 pointer-events-none z-0 rotate-3 group-hover:rotate-0">
                        <img src="/Screenshot 2025-12-26 at 0.40.41.png" class="w-full h-full object-cover shadow-2xl" />
                    </div>
                </div>

                <!-- Item 2 -->
                <div class="group border-t border-black/10 py-16 px-8 md:px-16 hover:bg-stone-50 transition-colors duration-500 cursor-pointer relative overflow-hidden">
                    <div class="flex flex-col md:flex-row justify-between items-baseline relative z-10">
                        <span class="text-sm font-mono text-gray-400 mb-4 md:mb-0">02</span>
                        <h3 class="text-4xl md:text-6xl font-light group-hover:translate-x-4 transition-transform duration-500">אדריכלות</h3>
                        <p class="text-base text-gray-500 max-w-xs mt-4 md:mt-0 text-left md:text-right">תכנון מבנים ובתים פרטיים</p>
                    </div>
                     <div class="hidden md:block absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 w-[400px] h-[300px] opacity-0 group-hover:opacity-100 transition-all duration-500 pointer-events-none z-0 -rotate-3 group-hover:rotate-0">
                        <img src="/Screenshot 2025-12-26 at 0.40.53.png" class="w-full h-full object-cover shadow-2xl" />
                    </div>
                </div>

                <!-- Item 3 -->
                <div class="group border-t border-b border-black/10 py-16 px-8 md:px-16 hover:bg-stone-50 transition-colors duration-500 cursor-pointer relative overflow-hidden">
                    <div class="flex flex-col md:flex-row justify-between items-baseline relative z-10">
                        <span class="text-sm font-mono text-gray-400 mb-4 md:mb-0">03</span>
                        <h3 class="text-4xl md:text-6xl font-light group-hover:translate-x-4 transition-transform duration-500">ייעוץ וליווי</h3>
                        <p class="text-base text-gray-500 max-w-xs mt-4 md:mt-0 text-left md:text-right">ליווי מקצועי וממוקד</p>
                    </div>
                     <div class="hidden md:block absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 w-[400px] h-[300px] opacity-0 group-hover:opacity-100 transition-all duration-500 pointer-events-none z-0 rotate-2 group-hover:rotate-0">
                        <img src="/Screenshot 2025-12-26 at 0.41.01.png" class="w-full h-full object-cover shadow-2xl" />
                    </div>
                </div>
            </div>
        </section>

		<!-- Contact - Minimal & Dark -->
		<section id="contact" class="py-32 px-8 md:px-16 bg-[#1a1a1a] text-white">
			<div class="max-w-4xl mx-auto text-center">
                <p class="text-sm font-bold tracking-[0.3em] uppercase text-gray-500 mb-8">Get in Touch</p>
				<h2 class="text-6xl md:text-9xl font-light tracking-tighter mb-16 leading-none">
                    יש לכם פרויקט?<br>בואו נדבר.
                </h2>
                
                <div class="flex flex-col md:flex-row justify-center gap-12 md:gap-24 mb-24 text-lg font-light text-gray-400">
                    <a href="mailto:Chila.eh@gmail.com" class="hover:text-white transition-colors">Chila.eh@gmail.com</a>
                    <a href="tel:054-339-5560" class="hover:text-white transition-colors">054-339-5560</a>
                    <span>יונתן 10, נווה שמיר, בית שמש</span>
                </div>

                <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="max-w-xl mx-auto space-y-0">
                    <div class="relative group">
                        <input type="text" id="name" name="name" placeholder="שם מלא" required 
                            class="w-full bg-transparent border-b border-white/20 py-6 text-xl placeholder-white/20 focus:outline-none focus:border-white transition-colors text-center">
                    </div>
                    <div class="relative group">
                        <input type="email" id="email" name="email" placeholder="אימייל" required 
                            class="w-full bg-transparent border-b border-white/20 py-6 text-xl placeholder-white/20 focus:outline-none focus:border-white transition-colors text-center">
                    </div>
                    <button type="submit" class="mt-16 px-16 py-4 border border-white/20 hover:bg-white hover:text-black transition-all duration-500 rounded-full text-sm tracking-[0.2em] uppercase">
                        שלח פרטים
                    </button>
                </form>
			</div>
		</section>
	</main>

    <footer class="bg-[#1a1a1a] text-white/40 py-12 px-8 md:px-16 border-t border-white/10 flex flex-col md:flex-row justify-between items-center text-xs tracking-widest uppercase">
        <p>&copy; {new Date().getFullYear()} Berger Studio</p>
        <div class="flex gap-8 mt-4 md:mt-0">
            <a href="#" class="hover:text-white transition-colors">Instagram</a>
            <a href="#" class="hover:text-white transition-colors">Pinterest</a>
        </div>
    </footer>
</Layout>

<style>
    /* Custom Animations */
    @keyframes ken-burns {
        0% { transform: scale(1); }
        100% { transform: scale(1.1); }
    }
    .animate-ken-burns {
        animation: ken-burns 20s ease-out infinite alternate;
    }
    
    .reveal-text {
        opacity: 0;
        transform: translateY(20px);
        animation: reveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes reveal {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    // Parallax Effect for Hero
    const heroBg = document.getElementById('parallax-bg');
    
    if (heroBg) {
        window.addEventListener('scroll', () => {
            const scrollPosition = window.scrollY;
            if (scrollPosition < window.innerHeight) {
                // Move the background down at 30% speed of scroll
                heroBg.style.transform = `translateY(${scrollPosition * 0.3}px)`;
            }
        }, { passive: true });
    }
</script>