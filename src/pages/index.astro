---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout
  title="עלמא | אדריכלות ועיצוב פנים"
  description="סטודיו עלמא של חני ברגר לאדריכלות ועיצוב פנים, עם דגש על חומרים טבעיים, דיוק תכנוני וחוויית מגורים רגישה."
>
  <Navbar />

  <main id="main-content" tabindex="-1" class="bg-white text-black">
    <section id="home" class="relative min-h-screen w-full overflow-hidden" aria-labelledby="hero-title">
      <div class="absolute inset-0">
        <div id="parallax-bg" class="absolute inset-0 h-[115%] -top-[15%] w-full will-change-transform">
          <img
            src="/hero-main.jpg"
            alt="סלון מונוכרומטי בגוונים רכים עם ספסל בנוי, חלונות גבוהים, מדפי עץ ואישה יושבת ליד החלון."
            class="w-full h-full object-cover object-[center_65%] animate-ken-burns grayscale saturate-0 contrast-110 brightness-90"
          />
        </div>
        <div class="absolute inset-0 bg-black/20 pointer-events-none" aria-hidden="true"></div>
      </div>

      <div class="relative z-10 h-full flex flex-col p-8 md:p-16 pb-12">
        <div class="max-w-[90vw] flex-1 flex flex-col justify-center md:justify-start md:pt-[14vh]">
          <div class="text-white text-right">
            <div
              class="flex flex-wrap items-baseline gap-x-6 md:gap-x-12 text-4xl md:text-5xl lg:text-6xl font-light opacity-90 mb-12 md:mb-20"
              aria-label="חומר, משמעות, צורה"
            >
              <span class="reveal-text" style="animation-delay: 0.1s">חומר.</span>
              <span class="reveal-text" style="animation-delay: 0.2s">משמעות.</span>
              <span class="reveal-text" style="animation-delay: 0.3s">צורה.</span>
            </div>

            <h1
              id="hero-title"
              class="text-white text-8xl md:text-[13vw] leading-[0.75] font-bold tracking-tighter reveal-text"
              style="animation-delay: 0.4s"
            >
              עלמא.
            </h1>

            <p
              class="text-xl md:text-3xl mt-12 md:mt-20 opacity-90 font-light tracking-[0.08em] reveal-text"
              style="animation-delay: 0.6s"
            >
              אדריכלות שבין אדם למקום.
            </p>
          </div>
        </div>

       
      </div>
    </section>

    <section
      id="portfolio"
      class="py-32 px-8 md:px-16 bg-white overflow-hidden"
      aria-labelledby="portfolio-heading"
    >
      <div class="max-w-[1800px] mx-auto">
        <div class="mb-32 flex justify-between items-end gap-8">
          <h2 id="portfolio-heading" class="text-5xl md:text-9xl font-light tracking-tighter text-black">
            עלמא
          </h2>
          <p
            class="text-sm font-bold tracking-[0.3em] uppercase text-stone-600 mb-4 hidden md:block"
            aria-hidden="true"
          >
            Gallery of Vision
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-y-48">
          <div class="md:col-span-5 group relative">
            <div class="aspect-[3/4] overflow-hidden bg-stone-100 mb-8">
              <img
                src="/Screenshot 2025-12-26 at 0.40.22.png"
                alt="חלל מגורים מינימליסטי בגוונים חמים עם ספה בהירה, קירות טבעיים וקווים נקיים."
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              />
            </div>
            <div class="max-w-md">
              <span class="text-xs font-mono text-stone-600 mb-2 block tracking-widest">STYLE 01</span>
              <h3 class="text-3xl font-light mb-4">מינימליזם אורגני</h3>
              <p class="text-xl text-stone-700 font-light leading-relaxed">
                המפגש בין קווים גיאומטריים נוקשים לבין חומרים טבעיים וצורות אמורפיות. יצירת חלל
                שנושם יחד עם דייריו.
              </p>
            </div>
          </div>

          <div class="md:col-span-7 md:mt-32 group relative">
            <div class="aspect-[16/9] overflow-hidden bg-stone-100 mb-8">
              <img
                src="/Screenshot 2025-12-26 at 0.40.33.png"
                alt="פנים בית מואר עם פתחים גבוהים, אור טבעי רך ומשטחים בהירים המדגישים את החלל."
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              />
            </div>
            <div class="max-w-xs mr-auto">
              <span class="text-xs font-mono text-stone-600 mb-2 block tracking-widest">STYLE 02</span>
              <h3 class="text-3xl font-light mb-4">דיאלוג עם האור</h3>
              <p class="text-xl text-stone-700 font-light leading-relaxed">
                האור הוא החומר השקוף ביותר בתהליך התכנון. אנחנו משתמשים בו כדי לפסל את החלל
                ולהעניק לו עומק משתנה לאורך שעות היום.
              </p>
            </div>
          </div>

          <div class="md:col-span-5 group relative">
            <div class="aspect-[4/5] overflow-hidden bg-stone-100 mb-8">
              <img
                src="/Screenshot 2025-12-26 at 0.40.41.png"
                alt="פינת פנים עם נגרות מדויקת, מדפים משולבים וחיבור עדין בין עץ, אבן וטיח."
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              />
            </div>
            <div class="max-w-sm">
              <span class="text-xs font-mono text-stone-600 mb-2 block tracking-widest">STYLE 03</span>
              <h3 class="text-3xl font-light mb-4">אדריכלות של פרטים</h3>
              <p class="text-xl text-stone-700 font-light leading-relaxed">
                אמונה שהשלם גדול מסכום חלקיו רק כאשר כל חלק מטופל בחרדת קודש. נגרות אומן, חיבורי
                חומרים ודיוק של מילימטרים.
              </p>
            </div>
          </div>

          <div class="md:col-span-7 md:-mt-32 group relative">
            <div class="aspect-[16/10] overflow-hidden bg-stone-100 mb-8 shadow-2xl md:z-10 relative">
              <img
                src="/Screenshot 2025-12-26 at 0.40.53.png"
                alt="חלל מגורים מאוזן המשלב אבן טבעית, עץ כהה, ריהוט רך ותאורה עדינה."
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              />
            </div>
            <div class="max-w-md md:mr-auto">
              <span class="text-xs font-mono text-stone-600 mb-2 block tracking-widest">STYLE 04</span>
              <h3 class="text-3xl font-light mb-4">חומרים שמרגישים</h3>
              <p class="text-xl text-stone-700 font-light leading-relaxed">
                אבן טבעית, עץ אלון מוברש וברזל חשוף. אנחנו בוחרים חומרים שמתיישנים בכבוד ומספרים
                סיפור של אותנטיות וחיבור לאדמה.
              </p>
            </div>
          </div>

          <div class="md:col-span-12 group relative border-t border-black/5 pt-32">
            <div class="aspect-[21/9] overflow-hidden bg-stone-100 mb-12">
              <img
                src="/Screenshot 2025-12-26 at 0.41.01.png"
                alt="חלל רחצה שקט ומפוסל עם אבן טבעית, משטחים רחבים ותאורה רכה ומפוזרת."
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              />
            </div>
            <div class="flex flex-col md:flex-row justify-between items-start gap-8">
              <div class="max-w-xl">
                <span class="text-xs font-mono text-stone-600 mb-2 block tracking-widest">STYLE 05</span>
                <h3 class="text-5xl font-light mb-6">מקדש של שקט</h3>
                <p class="text-2xl text-stone-700 font-light leading-relaxed">
                  חללי רחצה ו-Wellness שהופכים למפלט מהעולם החיצון. שימוש בשיש טבעי ובקווים נקיים
                  ליצירת חוויה של רוגע מוחלט.
                </p>
              </div>
              <div class="h-[1px] w-full md:w-64 bg-black self-end mb-4" aria-hidden="true"></div>
            </div>
          </div>

          <div class="md:col-span-6 group relative">
            <div class="aspect-[3/4] overflow-hidden bg-stone-100 mb-8">
              <img
                src="/WhatsApp Image 2025-12-26 at 01.38.00.jpeg"
                alt="מבואת כניסה נעימה עם חומרים חמים, קווים גיאומטריים רגועים ותאורה מזמינה."
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              />
            </div>
            <div class="max-w-md">
              <span class="text-xs font-mono text-stone-600 mb-2 block tracking-widest">STYLE 06</span>
              <h3 class="text-3xl font-light mb-4">המפגש הראשון</h3>
              <p class="text-xl text-stone-700 font-light leading-relaxed">
                עיצוב מבואת כניסה המשלב חומרים חמים עם אלמנטים גיאומטריים מזמינים. יצירת מעבר
                הדרגתי ונעים מהחוץ אל הפנים.
              </p>
            </div>
          </div>

          <div class="md:col-span-6 md:mt-32 group relative">
            <div class="aspect-[3/4] overflow-hidden bg-stone-100 mb-8">
              <img
                src="/WhatsApp Image 2025-12-26 at 01.40.12.jpeg"
                alt="מטבח כהה ומינימליסטי עם חזיתות עץ עמוקות, אי מרכזי ומשטח אבן טבעית."
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              />
            </div>
            <div class="max-w-md">
              <span class="text-xs font-mono text-stone-600 mb-2 block tracking-widest">STYLE 07</span>
              <h3 class="text-3xl font-light mb-4">דרמה מאופקת</h3>
              <p class="text-xl text-stone-700 font-light leading-relaxed">
                מטבחים במינימליזם כהה ומוקפד. שימוש בטקסטורות עץ עמוקות בשילוב אי מאבן טבעית
                ליצירת מראה יוקרתי ועל-זמני.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section
      id="about"
      class="py-32 md:py-48 px-8 md:px-16 max-w-[1800px] mx-auto"
      aria-labelledby="about-heading"
    >
      <div class="flex flex-col md:flex-row gap-24 items-start">
        <div class="w-full md:w-1/3 sticky top-32">
          <span class="text-xs font-bold tracking-[0.2em] uppercase text-stone-600 mb-8 block">
            The Studio
          </span>
          <h2 id="about-heading" class="text-5xl md:text-6xl font-light leading-tight mb-12">
            עיצוב שקט,<br />
            נוכחות עוצמתית.
          </h2>
          <div class="h-[1px] w-24 bg-black mb-12" aria-hidden="true"></div>
          <div class="flex flex-col gap-2">
            <span class="text-lg font-medium">חני ברגר</span>
            <span class="text-sm text-stone-700 uppercase tracking-widest">אדריכלית ראשית</span>
          </div>
        </div>

        <div class="w-full md:w-2/3 flex flex-col gap-32">
          <div class="relative group">
            <div class="overflow-hidden mb-8 aspect-[4/5] max-w-lg">
              <img
                src="/Chani.jpg"
                alt="דיוקן של חני ברגר, אדריכלית ומעצבת פנים, עומדת בחלל בהיר עם תאורה טבעית."
                class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105"
              />
            </div>
            <div class="md:pl-24 max-w-2xl space-y-8">
              <p class="text-xl md:text-2xl font-light leading-relaxed text-stone-800">
                בסטודיו עלמא אני מאמינה שאדריכלות ועיצוב פנים הם הרבה מעבר ליצירת חלל יפה - הם דרך
                לברוא מקום שיש בו שייכות, נוכחות, שקט ועומק. החזון שלי הוא ליצור בתים וחללים
                שמרגישים נכונים באמת: מדויקים למי שחי בהם, קשובים לאורח החיים שלהם, ולדרך שבה הם
                רוצים להרגיש ביום־יום. אני דוגלת באדריכלות שורשית - כזו שמחוברת לאדמה, לחומר, לזמן,
                ולאדם. אדריכלות שלא רודפת אחרי טרנדים או מחוות רגעיות, אלא מבקשת ליצור יסודות
                חזקים, יופי על־זמני, ופשטות שיש בה עומק.
              </p>
              <p class="text-lg font-light leading-relaxed text-stone-800">
                מבחינתי, תכנון טוב נולד מהקשבה אמיתית: הקשבה לאנשים, להרגלים שלהם, למה שנאמר וגם
                למה שלא תמיד יודעים לנסח במילים. מתוך ההקשבה הזו נבנה תהליך מדויק, רגיש ומאוד אישי,
                שבו כל החלטה נובעת ממשמעות ולא רק ממראה. אני מאמינה בחומריות כנה, בגוונים טבעיים,
                בקווים נקיים אך לא קרים, ובחללים שמצליחים להרגיש גם יציבים וגם רכים, גם מוקפדים וגם
                חיים.
              </p>
              <p class="text-lg font-light leading-relaxed text-stone-800">
                הערכים שמובילים אותי הם אמת, דיוק, קשב, מלאכה, פשטות, חמימות ונאמנות למקום - לא רק
                כמיקום פיזי, אלא כתחושת בית עמוקה. אני שואפת ליצור עבור הלקוחות שלי חללים שיש בהם
                סדר, נשימה ואיזון; חללים שמאפשרים לחיים לקרות בהם באמת, ביופי שקט ולא מתאמץ. עלמא
                עבורי היא תפיסה שלמה: חיבור בין חומר לרגש, בין פרקטיקה לאסתטיקה, בין בית כמבנה לבין
                בית כתחושה. זהו עיצוב שמבקש להחזיק חיים שלמים - משפחה, אירוח, שגרה, התבגרות,
                זיכרונות - ולתת להם מסגרת מדויקת, טבעית ועמוקה, שמרגישה נכונה גם היום וגם בעוד
                שנים.
              </p>

              <div class="pt-8 border-t border-black/10">
                <p class="text-lg font-light leading-relaxed text-stone-800 mb-6">
                  הסטודיו מביא עמו ניסיון עשיר של למעלה מ-8 שנים בתכנון מגה-פרויקטים ומבנים מורכבים
                  בארץ ובחו"ל. חני הובילה תכנון בפרויקטים אייקוניים כמו מגדלי
                  <strong class="font-normal"> Beyond (תדהר)</strong> – פרויקט הדגל בגבעתיים המשלב
                  מגדל משרדים בן 70 קומות ומגדל מגורים בן 45 קומות.
                </p>
                <p class="text-base font-light leading-relaxed text-stone-700">
                  הניסיון המקצועי שלה, שנצבר במשרד המוביל
                  <strong class="font-normal"> ברעלי לויצקי כסיף (B.L.K)</strong>, כולל עבודה על
                  פרויקטים רחבי היקף כמו "סביוני השרון" בנתניה ופרויקט "הגדוד העברי". יכולות אלו,
                  המשלבות ראייה אסטרטגית וניהול צוותים בינלאומיים, מתורגמות כיום לסטודיו בוטיק
                  המעניק תשומת לב אישית ודיוק אדריכלי חסר פשרות.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section
      id="values"
      class="py-32 px-8 md:px-16 max-w-[1800px] mx-auto border-t border-black/5"
      aria-labelledby="values-heading"
    >
      <div class="mb-24 flex justify-between items-end gap-8">
        <h2 id="values-heading" class="text-4xl md:text-8xl font-light tracking-tighter">ערכי ליבה</h2>
        <span class="text-xs font-bold tracking-[0.2em] uppercase text-stone-600 mb-4 hidden md:block" aria-hidden="true">
          Core Values
        </span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-24">
        <div class="group border-t border-black/10 pt-12">
          <span class="text-sm font-mono text-stone-600 mb-8 block">01</span>
          <h3 class="text-3xl md:text-4xl font-light mb-6">אנושיות</h3>
          <p class="text-xl text-stone-700 font-light leading-relaxed">
            אמונה בחשיבותם של חום, רגישות ושייכות בתוך החיים עצמם. ערך שמחזיק בתוכו את המשפחה,
            הלב, והשאיפה ליצור קשר ומרחב שיש בהם נוכחות, רוך ואותנטיות.
          </p>
        </div>

        <div class="group border-t border-black/10 pt-12">
          <span class="text-sm font-mono text-stone-600 mb-8 block">02</span>
          <h3 class="text-3xl md:text-4xl font-light mb-6">אמת</h3>
          <p class="text-xl text-stone-700 font-light leading-relaxed">
            חשוב לי לפעול מתוך כנות ונאמנות למה שמרגיש נכון באמת. אני מאמינה שדיוק אמיתי מתחיל
            ביושר - מול עצמי, מול הלקוחות, ומול התהליך.
          </p>
        </div>

        <div class="group border-t border-black/10 pt-12">
          <span class="text-sm font-mono text-stone-600 mb-8 block">03</span>
          <h3 class="text-3xl md:text-4xl font-light mb-6">מסירות</h3>
          <p class="text-xl text-stone-700 font-light leading-relaxed">
            אני מאמינה מכל הלב שאם עושים משהו אז הוא צריך להיעשות עד הסוף ובצורה הטובה והעמוקה
            ביותר.
          </p>
        </div>
      </div>
    </section>

    <section id="services" class="py-32 border-t border-gray-100" aria-labelledby="services-heading">
      <div class="px-8 md:px-16 mb-24 flex justify-between items-end gap-8">
        <h2 id="services-heading" class="text-4xl md:text-8xl font-light tracking-tighter">שירותים</h2>
        <span class="text-xs font-bold tracking-[0.2em] uppercase text-stone-600 mb-4 hidden md:block" aria-hidden="true">
          Expertise
        </span>
      </div>

      <div class="flex flex-col">
        <div class="group border-t border-black/10 py-16 px-8 md:px-16 hover:bg-stone-50 transition-colors duration-500 relative overflow-hidden">
          <div class="flex flex-col md:flex-row justify-between items-baseline relative z-10">
            <span class="text-sm font-mono text-stone-600 mb-4 md:mb-0">01</span>
            <h3 class="text-4xl md:text-6xl font-light group-hover:translate-x-4 transition-transform duration-500">
              עיצוב פנים
            </h3>
            <p class="text-base text-stone-700 max-w-xs mt-4 md:mt-0 text-left md:text-right">
              תכנון חללים מוקפד וטוטאלי
            </p>
          </div>
          <div
            class="hidden md:block absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 w-[400px] h-[300px] opacity-0 group-hover:opacity-100 transition-all duration-500 pointer-events-none z-0 rotate-3 group-hover:rotate-0"
            aria-hidden="true"
          >
            <img
              src="/Screenshot 2025-12-26 at 0.40.41.png"
              alt=""
              class="w-full h-full object-cover shadow-2xl"
            />
          </div>
        </div>

        <div class="group border-t border-black/10 py-16 px-8 md:px-16 hover:bg-stone-50 transition-colors duration-500 relative overflow-hidden">
          <div class="flex flex-col md:flex-row justify-between items-baseline relative z-10">
            <span class="text-sm font-mono text-stone-600 mb-4 md:mb-0">02</span>
