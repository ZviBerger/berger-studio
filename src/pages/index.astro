<style>
  @keyframes ken-burns {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.05);
    }
  }

  .animate-ken-burns {
    animation: ken-burns 30s ease-out infinite alternate;
  }

  .reveal-text {
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .arch-caption {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.2s,
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.2s;
  }

  .kitchen-sketch :global(.k-stroke) {
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .kitchen-reveal.is-drawing :global(.k-stroke) {
    clip-path: inset(0 0 0 0);
  }

  .kitchen-sketch :global(.k-stroke[data-k-type="large"]) {
    clip-path: none;
    opacity: 0;
    transition: opacity 0.9s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .kitchen-reveal.is-drawing :global(.k-stroke[data-k-type="large"]) {
    opacity: 1;
  }

  .kitchen-reveal.is-drawing .arch-caption {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .kitchen-sketch :global(.k-stroke),
    .arch-caption {
      transition: none !important;
    }
    .kitchen-sketch :global(.k-stroke) {
      clip-path: inset(0) !important;
      opacity: 1 !important;
    }
  }
</style>

<script>
  const heroBg = document.getElementById('parallax-bg');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (heroBg && !prefersReducedMotion) {
    window.addEventListener(
      'scroll',
      () => {
        const scrollPosition = window.scrollY;
        if (scrollPosition < window.innerHeight) {
          heroBg.style.transform = `translateY(${scrollPosition * 0.15}px)`;
        }
      },
      { passive: true },
    );
  }


  const kitchenReveals = document.querySelectorAll<HTMLElement>('.kitchen-reveal');
  kitchenReveals.forEach((section) => {
    const strokes = section.querySelectorAll<SVGPathElement>('.k-stroke');
    if (!strokes.length) return;

    const largeAreaThreshold = 150000;
    const stagger = 0.09;
    strokes.forEach((el, i) => {
      el.style.transitionDelay = `${(i * stagger).toFixed(2)}s`;
      try {
        const bbox = el.getBBox();
        if (bbox.width * bbox.height > largeAreaThreshold) {
          el.dataset.kType = 'large';
        }
      } catch {}
    });

    if (prefersReducedMotion) {
      section.classList.add('is-drawing');
      strokes.forEach((el) => {
        el.style.transitionDelay = '0s';
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          section.classList.add('is-drawing');
          observer.unobserve(section);
        });
      },
      { threshold: 0.18 },
    );

    observer.observe(section);
  });
</script>
