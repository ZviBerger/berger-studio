---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const kitchenSvgRaw = fs.readFileSync(path.resolve('./public/kitchen.svg'), 'utf-8');
const kitchenInnerPaths = kitchenSvgRaw
  .replace(/^[\s\S]*?<svg[^>]*>/, '')
  .replace(/<\/svg>\s*$/, '')
  .replace(/fill="#000000"/g, 'fill="currentColor"')
  .replace(/<path /g, '<path class="k-stroke" ');

const phoneDisplay = '054-339-5560';
const phoneHref = '+972543395560';
const whatsappHref = 'https://wa.me/972543395560';

const trustHighlights = [
  {
    value: '10+',
    label: 'שנות ניסיון',
    description: 'ניסיון נרחב בתכנון מגה-פרויקטים, מבנים מורכבים ובתים פרטיים.',
  },
  {
    value: 'Beyond',
    label: 'פרויקט דגל',
    description: 'לקיחת חלק בצוות התכנון של אחד מהפרויקטים האייקוניים והמורכבים בישראל.',
  },
  {
    value: 'Boutique',
    label: 'ליווי אישי',
    description: 'סטודיו בוטיק שמעניק הקשבה רגישה, דיוק תכנוני וזמינות אישית ומלאה.',
  },
];

const testimonials = [
  {
    quote:
      'את חני היה לי קל לבחור, בכל זאת, מדובר בבת שלי. כשהחלטנו לשפץ את המטבח בפעם השנייה ולהוסיף ממ"ד, חני נכנסה מיד לתמונה. בניגוד לשיפוץ בעבר שבו לא הייתה מספיק הקשבה לצרכים שלנו, חני ביצעה את העבודה גם במקצועיות וגם באנושיות יוצאת דופן. היא הקשיבה לחלומות שלי ועזרה להגשים אותם, מבלי להתפשר על פרקטיות ונוחות. השיפוץ קרה מהר, ללא זמן רב להתארגנות מראש, ולמרות זאת הכל נעשה בנחת וברוגע. חני הביאה לתכנון פתרונות וחידושים שלא הכרתי קודם, והיום אני לא מבינה איך הסתדרתי בלעדיהם. היא דאגה שהכל יבוצע על הצד הטוב ביותר. אין לי ספק שכאשר אצטרך בעתיד, אחזור ואבחר בה שוב.',
    author: 'אבישג ארליך',
    role: 'עיצוב מטבח, ירושלים',
    image: '/trust-kitchen.png',
    imageAlt:
      'מטבח לבן עם נגרות נקייה, נגיעת עץ טבעי במרכז, משטחי אבן ומראה מינימליסטי מוקפד.',
    tag: 'פרויקט פרטי',
  },
  {
    quote:
      'אדריכלית חני ברגר לקחה חלק בצוות התכנון של פרויקט Beyond ביוזמת חברת תדהר, פרויקט שאותו ניהלתי. מתוך היכרותי עימה כאדריכלית וכאדם, אני יכולה לומר בביטחון מלא שמדובר באשת מקצוע איכותית, חרוצה ומבריקה. חני מילאה בפרויקט כל משימה, קטנה כגדולה, תוך הגדלת ראש ומוטיבציה אמיתית להיטיב עם התכנון ועם התוצאה הסופית. היא יוזמת, מסורה ומחויבת להשגת יעדים באיכות הגבוהה ביותר. לצד כל אלו, חני היא אישה נעימה, אינטליגנטית ומשדרת חוכמה ויחסי אנוש מעולים. היא השתלבה באופן מושלם בצוות התכנון וזכתה להערכה רבה מצד הקולגות והמנהלים שעבדו לצידה. אני מאחלת לחני הצלחה רבה בכל דרך שתבחר.',
    author: 'גלית גת הורוביץ',
    role: 'סמנכ"ל איכות, חטיבת הניהול - תדהר',
    image: '/trust-beyond.jpg',
    imageAlt:
      'הדמיה אווירית של פרויקט Beyond עם מגדלי זכוכית מוארים במרכז המטרופולין.',
    tag: 'מגה-פרויקט',
  },
  {
    quote:
      'ברצוני להמליץ על חני ברגר, אדריכלית צעירה ומוכשרת שעבדה לצדי בפרויקט "סביוני השמורה" של אפריקה התחדשות עירונית, פרויקט פינוי בינוי רחב היקף שכלל תכנון של 512 יחידות דיור, מבנה ציבור ומבני מסחר. במהלך עבודתנו המשותפת הפגינה חני חריצות, יסודיות ומקצועיות יוצאות דופן. היא ניגשה לכל נושא בפרויקט בגישה נמרצת ומחויבת, תוך הפגנת אחריות מלאה ויכולת תכנון מדויקת ויצירתית כאחד. מעבר לכישוריה המקצועיים המרשימים, מדובר באשת מקצוע שירותית ונעימה, שיודעת להקשיב, להבין צרכים ולעבוד בשיתוף פעולה פורה עם כלל הגורמים המעורבים – מתכננים ויועצים כאחד. עבודה ברמה הגבוהה ביותר, בליווי אישי ומסור לכל אורך הדרך.',
    author: 'דקל רוקבן',
    role: 'מנהל פרויקטים, אפריקה ישראל מגורים',
    image: '/trust-savyoney.jpg',
    imageAlt: 'הדמיה של פרויקט סביוני השמורה עם מגדלי מגורים לבנים',
    tag: 'מגה-פרויקט',
  },
  {
    quote:
      'אני שמחה להמליץ בחום על חני ברגר שעובדת יחד איתי כמתכננת מול קבוצת גבאי. במהלך העבודה זכיתי להכיר אישה מקצועית, מוכשרת וחדורת מוטיבציה, שמביאה ערך מוסף לכל פרויקט בו היא לוקחת חלק. חני הפגינה יכולות יוצאות דופן בתחום האדריכלות, הן מבחינה תכנונית והן מבחינה יצירתית. היא מתמודדת עם אתגרים ברוגע, תוך מציאת פתרונות יעילים וחדשניים. כמו כן, היא מצטיינת בעבודה בצוות ושומרת על תקשורת חיובית ואפקטיבית עם כל הגורמים המעורבים בפרויקטים. כמנהלת פרויקטים בכירה, אני יכולה להעיד על תרומתה המשמעותית של חני ברגר להצלחת הפרויקטים שלנו. בזכות הידע המקצועי הנרחב שלה, לצד גישתה האחראית והמסורה, היא מצליחה לעמוד בלוחות זמנים ולספק תוצרים באיכות הגבוהה ביותר. אני ממליצה עליה בלב שלם לכל תפקיד או פרויקט עתידי, ואני בטוחה שתהיה תרומה משמעותית לכל ארגון או צוות שיזכה לעבוד איתה.',
    author: 'נופר שרגא',
    role: 'מנהלת פרויקטים בכירה קבוצת גבאי',
    image: '/trust-gabai.jpg',
    imageAlt: 'הדמיה של פרויקט מגורים מודרני עם שני מגדלים',
    tag: 'תכנון אדריכלי',
  },
];

const faqs = [
  {
    question: 'מהם השירותים שאדריכל ומעצב פנים מציע?',
    answer: 'השירותים כוללים תכנון אדריכלי, עיצוב פנים, עיצוב רהיטים בהתאמה אישית, ייעוץ בבחירת חומרי גמר, וליווי הפרויקט מהשלב הראשוני ועד לסיום הבנייה.'
  },
  {
    question: 'מה ההבדל בין אדריכל למעצב פנים?',
    answer: 'אדריכל עוסק בעיקר בתכנון המבנה כולו, כולל חלוקה פנימית וחיצונית, בהתאם לחוקי הבנייה. מעצב פנים מתמקד בעיצוב חללי הפנים של הבית, כולל בחירת חומרים, צבעים, רהיטים ועוד.'
  },
  {
    question: 'האם יש לכם ניסיון עם עיצוב דירות קטנות?',
    answer: 'בהחלט! לעיצוב חללים קטנים יש אתגרים ייחודיים, ואנחנו מיומנים במציאת פתרונות יצירתיים לניצול אופטימלי של המרחב.'
  },
  {
    question: 'איך מתחילים בתהליך עיצוב פנים?',
    answer: 'תחילה נפגש לפגישת ייעוץ כדי להבין את הצרכים, הסגנון והתקציב שלך. לאחר מכן נכין תוכנית עיצוב ראשונית, ובהמשך נתקדם לתכנון מפורט ולבחירת חומרים.'
  },
  {
    question: 'מהם השלבים בתהליך תכנון אדריכלי?',
    answer: 'שלבי התהליך כוללים פגישת ייעוץ, גיבוש קונספט ראשוני, יצירת תוכניות מפורטות, הגשת התוכניות לאישורים מול הרשויות, וליווי ופיקוח על ביצוע העבודה בשטח.'
  },
  {
    question: 'האם אתם עובדים גם על פרויקטים מסחריים?',
    answer: 'כן, אנחנו עובדים על פרויקטים למגורים ולמסחר, כולל משרדים, חנויות, מסעדות ועוד.'
  },
  {
    question: 'כמה זמן לוקח פרויקט אדריכלי או עיצוב פנים?',
    answer: 'משך הפרויקט משתנה בהתאם להיקף העבודה, אך ניתן לצפות לפרויקט תכנון ועיצוב בית חדש שיימשך בין מספר חודשים ועד שנה או יותר.'
  },
  {
    question: 'מה עלות שירותי אדריכלות ועיצוב פנים?',
    answer: 'העלות משתנה בהתאם לגודל הפרויקט ולמורכבותו. ניתן לתאם פגישת ייעוץ לקבלת הצעת מחיר מותאמת אישית.'
  },
  {
    question: 'האם יש צורך באישור תכניות לפני תחילת בנייה?',
    answer: 'כן, רוב הפרויקטים דורשים אישורים מול הרשויות, ואנחנו מטפלים בכל הניירת והאישורים הנדרשים כחלק מהשירות.'
  },
  {
    question: 'מהם סגנונות העיצוב הפופולריים שאתם עובדים איתם?',
    answer: 'אנו מתמחים בסגנונות מגוונים כגון מודרני, כפרי, תעשייתי, סקנדינבי, וקלאסי. הסגנון מותאם לטעמכם האישי ולצרכים הייחודיים שלכם.'
  },
  {
    question: 'האם אתם עובדים עם ספקים ורהיטים בהתאמה אישית?',
    answer: 'כן, אנו עובדים עם ספקים מובילים וגם מציעים עיצוב רהיטים בהתאמה אישית כדי להתאים כל פרט לסגנון ולחזון שלכם.'
  },
  {
    question: 'איך אפשר לשמור על תקציב במהלך הפרויקט?',
    answer: 'נבנה תכנית תקציב מפורטת ונבצע מעקב אחר כל שלב, כך שנוכל להקפיד על מסגרת תקציב ולבחור חומרים שמתאימים לתקציב מבלי להתפשר על איכות.'
  }
];
---

<Layout
  title="עלמא | אדריכלות ועיצוב פנים"
  description="סטודיו עלמא של חני ברגר לאדריכלות ועיצוב פנים, עם דגש על חומרים טבעיים, דיוק תכנוני וחוויית מגורים רגישה."
>
  <Navbar />

  <main id="main-content" tabindex="-1" class="bg-white text-black">
    <section id="home" class="relative min-h-screen w-full overflow-hidden" aria-labelledby="hero-title">
      <div class="absolute inset-0">
        <div id="parallax-bg" class="absolute inset-0 h-[115%] -top-[15%] w-full will-change-transform">
          <img
            src="/hero-new.jpg"
            alt="סלון מונוכרומטי בגוונים רכים עם ספסל בנוי, חלונות גבוהים, מדפי עץ ואישה יושבת ליד החלון."
            class="w-full h-full object-cover object-[center_65%] animate-ken-burns grayscale saturate-0 contrast-110 brightness-90"
          />
        </div>
        <div class="absolute inset-0 bg-black/20 pointer-events-none" aria-hidden="true"></div>
      </div>

      <div class="relative z-10 min-h-screen flex flex-col p-8 md:p-16 pb-12">
        <div class="max-w-[90vw] flex-1 flex flex-col justify-center md:justify-start md:pt-[14vh]">
          <div class="text-white text-right">
            <div
              class="flex flex-wrap items-baseline gap-x-6 md:gap-x-12 text-3xl md:text-5xl lg:text-6xl font-light opacity-90 mb-8 md:mb-20 font-cardo"
              aria-label="חומר, משמעות, צורה"
            >
              <span class="reveal-text" style="animation-delay: 0.1s">חומר.</span>
              <span class="reveal-text" style="animation-delay: 0.2s">משמעות.</span>
              <span class="reveal-text" style="animation-delay: 0.3s">צורה.</span>
            </div>

            <h1
              id="hero-title"
              class="text-white text-7xl md:text-[13vw] leading-[0.78] md:leading-[0.75] font-bold tracking-tighter reveal-text"
              style="animation-delay: 0.4s"
            >
              עלמא.
            </h1>

            <p
              class="text-lg md:text-3xl mt-8 md:mt-20 opacity-90 font-light tracking-[0.08em] reveal-text font-cardo"
              style="animation-delay: 0.6s"
            >
              אדריכלות שבין אדם למקום.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section
      id="portfolio"
      class="py-32 px-8 md:px-16 bg-white overflow-hidden"
      aria-labelledby="portfolio-heading"
    >
      <div class="max-w-[1800px] mx-auto">
        <div class="mb-20 md:mb-32 border-b border-black/5 pb-10 md:pb-14">
          <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-8 md:gap-12">
            <div class="max-w-2xl">
              <p class="text-xs md:text-sm font-bold tracking-[0.3em] uppercase text-stone-600 mb-5">
                Gallery of Vision
              </p>
              <h2
                id="portfolio-heading"
                class="text-4xl md:text-6xl font-light tracking-tighter text-black"
              >
                עלמא
              </h2>
            </div>
            <p class="max-w-md text-lg md:text-xl text-stone-600 font-light leading-relaxed md:text-right">
              שפה אדריכלית שנעה בין חומר, אור ודיוק. כל פריים מספר רגע אחר מתוך אותה תפיסה
              של שקט, נוכחות ועומק.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-16 md:gap-x-12 md:gap-y-40">
          <div class="md:col-span-5 group relative">
            <div class="aspect-[3/4] overflow-hidden bg-stone-100 mb-8 md:max-w-[32rem]">
              <img
                src="/Screenshot 2025-12-26 at 0.40.22.png"
                alt="חלל מגורים מינימליסטי בגוונים חמים עם ספה בהירה, קירות טבעיים וקווים נקיים."
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              />
            </div>
            <div class="max-w-md md:pr-6">
              <span class="text-xs font-mono text-stone-600 mb-2 block tracking-widest">STYLE 01</span>
              <h3 class="text-3xl font-light mb-4">מינימליזם אורגני</h3>
              <p class="text-xl text-stone-700 font-light leading-relaxed">
                המפגש בין קווים גיאומטריים נוקשים לבין חומרים טבעיים וצורות אמורפיות. יצירת חלל
                שנושם יחד עם דייריו.
              </p>
            </div>
          </div>

          <div class="md:col-span-7 md:mt-32 group relative">
            <div class="aspect-[16/9] overflow-hidden bg-stone-100 mb-8 md:max-w-[46rem] md:mr-0 md:ml-auto">
              <img
                src="/Screenshot 2025-12-26 at 0.40.33.png"
                alt="פנים בית מואר עם פתחים גבוהים, אור טבעי רך ומשטחים בהירים המדגישים את החלל."
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              />
            </div>
            <div class="max-w-sm md:mr-12">
              <span class="text-xs font-mono text-stone-600 mb-2 block tracking-widest">STYLE 02</span>
              <h3 class="text-3xl font-light mb-4">דיאלוג עם האור</h3>
              <p class="text-xl text-stone-700 font-light leading-relaxed">
                האור הוא החומר השקוף ביותר בתהליך התכנון. אנחנו משתמשים בו כדי לפסל את החלל
                ולהעניק לו עומק משתנה לאורך שעות היום.
              </p>
            </div>
          </div>

          <div class="md:col-span-5 group relative">
            <div class="aspect-[4/5] overflow-hidden bg-stone-100 mb-8 md:max-w-[30rem]">
              <img
                src="/Screenshot 2025-12-26 at 0.40.41.png"
                alt="פינת פנים עם נגרות מדויקת, מדפים משולבים וחיבור עדין בין עץ, אבן וטיח."
                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
              />
            </div>
            <div class="max-w-sm md:pr-6">
              <span class="text-xs font-mono text-stone-600 mb-2 block tracking-widest">STYLE 03</span>
              <h3 class="text-3xl font-light mb-4">אדריכלות של פרטים</h3>
              <p class="text-xl text-stone-700 font-light leading-relaxed">
                אמונה שהשלם גדול מסכום חלקיו רק כאשר כל חלק מטופל בחרדת קודש. נגרות אומן, חיבורי
                חומרים ודיוק של מילימטרים.
              </p>
            </div>
          </div>

          <div class="md:col-span-7 md:-mt-32 group relative">
