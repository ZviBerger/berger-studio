---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Berger Studio - Architecture & Interior Design" } = Astro.props;
---

<!doctype html>
<html lang="he" dir="rtl" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        
        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@100..900&display=swap" rel="stylesheet">
        
		<title>{title}</title>
	</head>
	<body class="bg-[#fcfcfc] text-berger-brown min-h-screen flex flex-col antialiased">
		<slot />
	</body>
</html>

