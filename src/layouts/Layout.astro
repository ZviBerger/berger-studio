---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	ogType?: 'website' | 'article';
	ogImageWidth?: number;
	ogImageHeight?: number;
	ogImageMimeType?: string;
}

const defaultOgImage = '/preview-v4.jpg';

const {
	title,
	description = 'עלמא - אדריכלות ועיצוב פנים',
	ogImage = defaultOgImage,
	ogType = 'website',
	ogImageWidth,
	ogImageHeight,
	ogImageMimeType,
} = Astro.props;

const siteUrl = Astro.site;
const canonicalUrl = siteUrl
	? new URL(Astro.url.pathname, siteUrl).toString()
	: Astro.url.toString();
const ogImageUrl = siteUrl ? new URL(ogImage, siteUrl).toString() : ogImage;
const resolvedOgImageWidth = ogImage === defaultOgImage ? 1200 : ogImageWidth;
const resolvedOgImageHeight = ogImage === defaultOgImage ? 1200 : ogImageHeight;
const resolvedOgImageMimeType = ogImage === defaultOgImage ? 'image/jpeg' : ogImageMimeType;
---

<!doctype html>
<html lang="he" dir="rtl" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#fcfcfc" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:locale" content="he_IL" />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="עלמא" />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:secure_url" content={ogImageUrl} />
		{resolvedOgImageMimeType && <meta property="og:image:type" content={resolvedOgImageMimeType} />}
		{resolvedOgImageWidth && <meta property="og:image:width" content={String(resolvedOgImageWidth)} />}
		{resolvedOgImageHeight && <meta property="og:image:height" content={String(resolvedOgImageHeight)} />}
		<meta property="og:image:alt" content={title} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cardo:ital,wght@0,400;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
		<script
			src="https://cdn.jsdelivr.net/npm/sienna-accessibility@latest/dist/sienna-accessibility.umd.js"
			defer
		></script>

		<title>{title}</title>
	</head>
	<body class="bg-[#fcfcfc] text-berger-brown min-h-screen flex flex-col antialiased">
		<a class="skip-link" href="#main-content">דלגו לתוכן הראשי</a>
		<slot />
	</body>
</html>
